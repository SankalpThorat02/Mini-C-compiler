{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build compiler",
      "type": "shell",
      "command": "flex lexer.l && bison -d parser.y && gcc lex.yy.c parser.tab.c ast.c symTab.c semantic.c tac.c main.c -o compiler"
    },
    {
      "label": "run compiler",
      "type": "shell",
      "command": "./compiler < input.txt > output.txt",
      "dependsOn": "build compiler",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "clean",
      "type": "shell",
      "command": "rm -f compiler lex.yy.c parser.tab.*"
    }
  ]
}